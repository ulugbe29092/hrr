# Vercel Environment Variables
# Vercel dashboard'da Settings → Environment Variables bo'limiga quyidagilarni qo'shing

# ============================================
# MAJBURIY (3 ta)
# ============================================

# 1. DATABASE_URL
# Qayerdan olish: Vercel → Storage → Create Database → Postgres → Connection string
# Yoki: https://neon.tech → New Project → Connection string
DATABASE_URL=postgres://default:xxxxx@ep-xxxxx-pooler.us-east-1.postgres.vercel-storage.com:5432/verceldb?sslmode=require

# 2. NEXTAUTH_SECRET
# Yaratish: Terminal'da `openssl rand -base64 32` ishga tushiring
NEXTAUTH_SECRET=J8kF9mN2pQ5rT7vX0yZ3aB6cD8eF1gH4iJ7kL9mN2pQ5rT7vX0yZ3aB6cD8eF1gH

# 3. NEXTAUTH_URL
# Deploy tugagach Vercel bergan URL'ni qo'ying
NEXTAUTH_URL=https://your-app-name.vercel.app

# ============================================
# IXTIYORIY (Rasm yuklash uchun)
# ============================================

# 4. CLOUDINARY_CLOUD_NAME
# Qayerdan olish: https://cloudinary.com → Dashboard → Cloud Name
CLOUDINARY_CLOUD_NAME=your_cloud_name

# 5. CLOUDINARY_API_KEY
# Qayerdan olish: https://cloudinary.com → Dashboard → API Key
CLOUDINARY_API_KEY=123456789012345

# 6. CLOUDINARY_API_SECRET
# Qayerdan olish: https://cloudinary.com → Dashboard → API Secret
CLOUDINARY_API_SECRET=your_api_secret_here

# ============================================
# QANDAY QO'SHISH
# ============================================
# 1. Vercel dashboard → Project → Settings → Environment Variables
# 2. "Add New" tugmasini bosing
# 3. Name va Value kiriting (yuqoridagi qiymatlarni o'zingizniki bilan almashtiring)
# 4. Environment: Production, Preview, Development (hammasini belgilang)
# 5. "Save" bosing
# 6. Har bir variable uchun qaytaring (jami 3 yoki 6 marta)
