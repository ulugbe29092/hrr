# Vercel Environment Variables
# Bu faylni Vercel dashboard'da Settings → Environment Variables bo'limiga qo'shing

# 1. DATABASE_URL (Majburiy)
# Vercel Postgres, Neon, yoki Supabase'dan oling
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# 2. NEXTAUTH_SECRET (Majburiy)
# Terminal'da yarating: openssl rand -base64 32
NEXTAUTH_SECRET="your-very-long-random-secret-key-here-change-this"

# 3. NEXTAUTH_URL (Majburiy)
# Vercel deploy qilgandan keyin avtomatik URL
NEXTAUTH_URL="https://your-app-name.vercel.app"

# 4. CLOUDINARY (Ixtiyoriy - Rasm yuklash uchun)
# https://cloudinary.com dan oling
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="123456789012345"
CLOUDINARY_API_SECRET="your_api_secret_here"

# 5. SOCKET_SERVER_URL (Ixtiyoriy)
SOCKET_SERVER_URL="https://your-socket-server.com"

# 6. NODE_ENV (Avtomatik)
NODE_ENV="production"
