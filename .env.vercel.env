# ==============================================
# VERCEL ENVIRONMENT VARIABLES
# ==============================================
# Vercel dashboard'da Settings → Environment Variables
# Har birini alohida "Add New" bilan qo'shing
# ==============================================

# 1. DATABASE_URL (MAJBURIY)
# Qayerdan: Vercel → Storage → Create Database → Postgres → Connection string
# Yoki: https://neon.tech → New Project → Connection string
DATABASE_URL=postgres://default:xxxxx@ep-xxxxx-pooler.us-east-1.postgres.vercel-storage.com:5432/verceldb?sslmode=require

# 2. NEXTAUTH_SECRET (MAJBURIY)
# Yaratish: Terminal'da `openssl rand -base64 32` ishga tushiring
# Yoki: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=J8kF9mN2pQ5rT7vX0yZ3aB6cD8eF1gH4iJ7kL9mN2pQ5rT7vX0yZ3aB6cD8eF1gH

# 3. NEXTAUTH_URL (MAJBURIY)
# Deploy tugagach Vercel bergan URL'ni qo'ying
# Hozircha: https://temp.vercel.app
# Keyin: https://your-app-name.vercel.app
NEXTAUTH_URL=https://your-app-name.vercel.app

# ==============================================
# IXTIYORIY (Rasm yuklash uchun)
# ==============================================

# 4. CLOUDINARY_CLOUD_NAME
# Qayerdan: https://cloudinary.com → Dashboard → Cloud Name
CLOUDINARY_CLOUD_NAME=your_cloud_name

# 5. CLOUDINARY_API_KEY
# Qayerdan: https://cloudinary.com → Dashboard → API Key
CLOUDINARY_API_KEY=123456789012345

# 6. CLOUDINARY_API_SECRET
# Qayerdan: https://cloudinary.com → Dashboard → API Secret
CLOUDINARY_API_SECRET=your_api_secret_here

# ==============================================
# QANDAY QO'SHISH (Vercel'da)
# ==============================================
# 1. Vercel dashboard → Project → Settings → Environment Variables
# 2. "Add New" tugmasini bosing
# 3. Name: DATABASE_URL
# 4. Value: Yuqoridagi qiymatni o'zingizniki bilan almashtiring
# 5. Environment: Production, Preview, Development (hammasini belgilang)
# 6. "Save" bosing
# 7. Har bir variable uchun qaytaring (jami 3 yoki 6 marta)

# ==============================================
# BUILD SETTINGS (Vercel'da)
# ==============================================
# Framework Preset: Next.js
# Root Directory: ./
# Build Command: pnpm run build
# Output Directory: .next
# Install Command: pnpm install
